# Terraform / OpenTofu
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.*
terraform/crash.log
terraform/crash.*.log
terraform/override.tf
terraform/override.tf.json
terraform/*_override.tf
terraform/*_override.tf.json
terraform/.terraformrc
terraform/terraform.rc

# Generated Lambda zips (built by archive_file)
terraform/*.zip

# tfvars often contain secrets / personal data
terraform/*.tfvars

# Python
__pycache__/
*.pyc

# macOS
.DS_Store
